<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:counter="clr-namespace:Counter"
        x:Class="Counter.MainWindow"
        x:DataType="counter:CounterViewModel"
        Title="Rx3 Counter"
        Width="320" Height="240">
  <StackPanel Spacing="12" Margin="20" VerticalAlignment="Center">
    <TextBlock Text="{Binding Count}" FontSize="48"
               HorizontalAlignment="Center" />
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
      <Button Command="{Binding DecrementCommand}" Content="-"
              Width="48" Height="48" FontSize="24" />
      <Button Command="{Binding IncrementCommand}" Content="+"
              Width="48" Height="48" FontSize="24" />
    </StackPanel>
    <Button Command="{Binding ResetCommand}" Content="Reset"
            HorizontalAlignment="Center" />
  </StackPanel>
</Window>
